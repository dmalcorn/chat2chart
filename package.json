{
  "name": "chat2chart",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered workflow discovery tool. Workers describe how they do their jobs through voice conversations with an AI interview agent. Multiple interviews are synthesized into normalized workflows with divergence annotations. Output is structured JSON (Process Schema), visualized as Mermaid.js flowcharts.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude='**/db/**/*.test.ts'",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmalcorn/chat2chart.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dmalcorn/chat2chart/issues"
  },
  "homepage": "https://github.com/dmalcorn/chat2chart#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "0.85.0",
    "@base-ui/react": "1.3.0",
    "bcrypt": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "compromise": "14.15.0",
    "drizzle-orm": "0.45.2",
    "jose": "6.2.2",
    "lucide-react": "1.7.0",
    "mermaid": "11.14.0",
    "next": "16.2.2",
    "postgres": "3.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.2",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@types/bcrypt": "6.0.0",
    "@types/node": "22.15.2",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@vitejs/plugin-react": "4.5.2",
    "drizzle-kit": "0.31.10",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "16.4.0",
    "playwright": "1.59.1",
    "prettier": "3.8.1",
    "shadcn": "4.2.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "7.3.2",
    "vitest": "4.1.2"
  }
}
