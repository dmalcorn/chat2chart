# Database — docker-compose.yml overrides this to use the 'db' service hostname
# This value works for non-Docker local dev; Docker uses the compose override
DATABASE_URL=postgresql://chat2chart:chat2chart_dev@localhost:5432/chat2chart

# LLM Provider (Claude — sole provider for MVP)
ANTHROPIC_API_KEY=sk-ant-...

# Session Management
SESSION_SECRET=generate-a-random-secret-at-least-32-chars

# Supervisor Access
SUPERVISOR_EMAIL_ALLOWLIST=supervisor@example.com
FIRST_SUPERVISOR_EMAIL=supervisor@example.com
FIRST_SUPERVISOR_PASSWORD=change-me-on-first-deploy

# Runtime
NODE_ENV=development
