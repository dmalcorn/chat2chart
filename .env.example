# Database — docker-compose.yml overrides this to use the 'db' service hostname
# This value works for non-Docker local dev; Docker uses the compose override
DATABASE_URL=postgresql://chat2chart:chat2chart_dev@localhost:5432/chat2chart

# LLM Provider (Claude — sole provider for MVP)
ANTHROPIC_API_KEY=sk-ant-...

# Session Management
SESSION_SECRET=generate-a-random-secret-here

# PM Access (infrastructure parity — no PM UI in demo)
PM_EMAIL_ALLOWLIST=admin@example.com
FIRST_PM_EMAIL=admin@example.com
FIRST_PM_PASSWORD=change-me-on-first-deploy

# Runtime
NODE_ENV=development
